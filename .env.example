# ── MongoDB ─────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
DB_NAME=fastapi_demo

# ── Provider switch ─────────────────────────────
# Options: openai | ollama
LLM_PROVIDER=ollama

# ── OpenAI ──────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Ollama (local) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
